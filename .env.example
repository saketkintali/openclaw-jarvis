# OpenClaw Gateway
WHATSAPP_TARGET=+15551234567        # Your WhatsApp number (E.164 format)
GATEWAY_TOKEN=your_gateway_token    # From openclaw.json → gateway.token

# Groq API — console.groq.com
GROQ_API_KEY=gsk_...

# Default weather/time location (used when no location is specified)
DEFAULT_LOCATION=10001              # ZIP code or city name
DEFAULT_LOCATION_NAME=New York      # Human-readable label

# Zapier MCP — for Google Calendar and Gmail via Zapier AI Actions
# 1. Go to zapier.com/ai-actions and add: Gmail Find Email, Google Calendar Find Events,
#    Google Calendar Quick Add Event, Google Calendar Delete Event
# 2. Go to the MCP tab, copy the connection URL
# 3. Paste it into workspace/config/mcporter.json replacing YOUR_ZAPIER_MCP_TOKEN
