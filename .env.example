# OpenClaw Gateway
WHATSAPP_TARGET=+15551234567        # Your WhatsApp number (E.164 format)
GATEWAY_TOKEN=your_gateway_token    # From openclaw.json → gateway.token

# Groq API — console.groq.com
GROQ_API_KEY=gsk_...

# Default weather/time location (used when no location is specified)
DEFAULT_LOCATION=10001              # ZIP code or city name
DEFAULT_LOCATION_NAME=New York      # Human-readable label

# TMDB — for movie/actor/director queries
# Free API key at: themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Zapier MCP — for Gmail and Google Calendar
# 1. Go to mcp.zapier.com → create or open your MCP Server
# 2. Add tools: Gmail (Find Email) + Google Calendar (Find Events, Quick Add Event)
# 3. Click the Connect tab → copy the MCP Server URL
# 4. Paste it into workspace/config/mcporter.json replacing YOUR_ZAPIER_MCP_TOKEN
